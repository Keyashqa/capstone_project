# Marvis — environment variables
# Copy to `.env` and fill in the Google OAuth values. NEVER commit `.env`.
# Every variable below is read by app/config.py. All have sensible defaults
# except the Google OAuth credentials, which you must provide for gdocs to work.
# The OAuth *token cache* (~/.google_workspace_mcp/credentials/) is gitignored.

# ── Google OAuth for the gdocs MCP tools (REQUIRED) ───────────────────────────
# Create an OAuth 2.0 "Desktop app" client at console.cloud.google.com with the
# Google Docs API + Google Drive API enabled, then paste the id/secret here.
GOOGLE_OAUTH_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-your_client_secret_here
USER_GOOGLE_EMAIL=your_email@gmail.com
WORKSPACE_MCP_ENABLED_TOOLS=docs,drive          # which workspace tool groups to enable
MCP_SINGLE_USER_MODE=true                        # single-user OAuth cache mode

# Path to the vendored google-workspace-mcp checkout (the real MCP server).
# Defaults to ../mcp-test/google_workspace_mcp relative to this folder.
# GDOCS_MCP_CWD=/abs/path/to/mcp-test/google_workspace_mcp

# ── Model (local Ollama — no API key needed) ──────────────────────────────────
MODEL_NAME=ollama/gemma2:2b                      # ADK-style model id used by the workflow
OLLAMA_MODEL=gemma2:2b                            # bare Ollama tag (run `ollama pull gemma2:2b`)

# ── Ports / service URLs ──────────────────────────────────────────────────────
MARVIS_HOST=0.0.0.0
MARVIS_PORT=8000
BROKER_BASE_URL=http://localhost:8002
PROXY_BASE_URL=http://localhost:8003             # proxy is a stub (parked in references/); unused at runtime

# ── Auth & capability grants ──────────────────────────────────────────────────
TOKEN_TTL_HOURS=72                               # login session token lifetime
GRANT_TTL_SECONDS=300                            # capability grant TTL (5 min)
DISPATCH_TIMEOUT_SECONDS=120                      # max seconds for a specialist run (CPU model)

# ── SQLite ────────────────────────────────────────────────────────────────────
# Defaults to marvis.db in this folder if unset.
# MARVIS_DB_PATH=/abs/path/to/marvis.db

# ── Marketplace commission (the 3-way payout split) ───────────────────────────
COMMISSION_RATE_BPS=1000                          # 1000 bps = 10% platform commission
COMMISSION_BASIS=completion                        # commission taken on the completion fee only

# ── Phase 3 demo seed (LOCAL demo accounts — NOT real secrets) ────────────────
# On startup, seeds a real seller + a funded buyer + one marketplace listing so
# the earnings loop is demonstrable without a signup UI. Set DEMO_SEED_ENABLED=false
# to disable. These values carry no security meaning — they are demo-only.
DEMO_SEED_ENABLED=true
DEMO_SELLER_ID=alice                              # == users.id == owner_id of the listing
DEMO_SELLER_EMAIL=alice@marvis.local
DEMO_BUYER_ID=operator                            # the funded hirer
DEMO_BUYER_EMAIL=operator@marvis.local
DEMO_PASSWORD=marvis-demo                          # demo-only login password
DEMO_PIN=1234                                       # demo-only PIN for both gates
DEMO_BUYER_TOPUP_CENTS=5000                         # $50.00 starting balance for the buyer
DEMO_LISTING_SLUG=twitter-writer                    # the marketplace slug alice lists
