# Marvis — environment variables
# Copy to .env and fill in your values (never commit .env)

# Ports
MARVIS_PORT=8000
BROKER_PORT=8002
PROXY_PORT=8003

# Model (local Ollama — no API key needed)
OLLAMA_MODEL=gemma2:2b

# Google OAuth for the gdocs MCP tools (mcp-test/google_workspace_mcp)
# One-time browser consent; no per-call API keys.
GOOGLE_OAUTH_CLIENT_ID=your_client_id_here
GOOGLE_OAUTH_CLIENT_SECRET=your_client_secret_here
WORKSPACE_MCP_ENABLED_TOOLS=docs,drive
MCP_SINGLE_USER_MODE=true
USER_GOOGLE_EMAIL=your_email@gmail.com

# DB paths (defaults to marvis.db and broker.db in project root)
# MARVIS_DB_PATH=/path/to/marvis.db
# BROKER_DB_PATH=/path/to/broker.db
