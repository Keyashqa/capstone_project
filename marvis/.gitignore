# Secrets — NEVER commit
.env
*.env
client_secret*.json
*credentials*.json
token*.json

# Google OAuth token cache
.google_workspace_mcp/

# Per-user JWK key pairs (auto-generated at first login)
app/_keys/*.json
broker_server/_keys/*.json

# Databases (runtime state, not source)
*.db
*.db-wal
*.db-shm

# ADK session state
app/.adk/

# Python
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
.eggs/

# Virtual environment
.venv/

# Pytest
.pytest_cache/
.coverage

# Frontend build artifacts
frontend/node_modules/
frontend/dist/
frontend/.vite/
*.tsbuildinfo

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*~
